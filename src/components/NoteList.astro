---
import type { CollectionEntry } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/config";

const { page } = Astro.props;
const interval = 40;

function getMonthLabel(monthNumber: number): string {
	const lang = (siteConfig.lang || "en").toLowerCase();
	if (lang.startsWith("zh") || lang.startsWith("ja")) return `${monthNumber}月`;
	if (lang.startsWith("ko")) return `${monthNumber}월`;
	const names = [
		"Jan",
		"Feb",
		"Mar",
		"Apr",
		"May",
		"Jun",
		"Jul",
		"Aug",
		"Sep",
		"Oct",
		"Nov",
		"Dec",
	];
	if (!Number.isFinite(monthNumber) || monthNumber < 1 || monthNumber > 12)
		return String(monthNumber);
	return names[monthNumber - 1];
}

const notes = await Promise.all(
	page.data.map(async (entry: CollectionEntry<"notes">) => {
		const { Content } = await entry.render();
		const publishedLabel = formatDateToYYYYMMDD(entry.data.published);
		const updatedLabel =
			entry.data.updated &&
			entry.data.updated.getTime() !== entry.data.published.getTime()
				? formatDateToYYYYMMDD(entry.data.updated)
				: null;
		const [year, month, day] = publishedLabel.split("-");
		const monthNum = Number.parseInt(month, 10);
		const dayNum = Number.parseInt(day, 10);
		return {
			entry,
			Content,
			publishedLabel,
			updatedLabel,
			dateParts: {
				year,
				month:
					Number.isFinite(monthNum) && monthNum >= 1 && monthNum <= 12
						? getMonthLabel(monthNum)
						: month,
				day: Number.isFinite(dayNum) ? String(dayNum).padStart(2, "0") : day,
			},
		};
	}),
);
---

<div class="notes-wrapper card-base">
<ul class="note-timeline">
    {notes.map((item, index) => {
        const Content = item.Content;
        const images: string[]   = item.entry.data.images ?? [];
        const tags: string[]     = item.entry.data.tags ?? [];
        const mood: string       = item.entry.data.mood ?? "";
        const location: string   = item.entry.data.location ?? "";
        const updatedDateTime    = item.entry.data.updated?.toISOString();

        return (
            <li
                class:list={[
                    "note-timeline__item onload-animation",
                    item.entry.data.pinned && "note-timeline__item--pinned",
                ]}
                style={`animation-delay: calc(var(--content-delay) + ${index * interval}ms);`}
            >
                {/* ── 左：日期 ── */}
                <div class="note-timeline__time">
                    <span class="note-timeline__day">{item.dateParts.day}</span>
                    <span class="note-timeline__month">{item.dateParts.month}</span>
                    <span class="note-timeline__year">{item.dateParts.year}</span>
                </div>

                {/* ── 中：轴线 ── */}
                <div class="note-timeline__axis" aria-hidden="true">
                    <span class:list={[
                        "note-timeline__dot",
                        item.entry.data.pinned && "note-timeline__dot--pinned",
                    ]}></span>
                </div>

                {/* ── 右：卡片 ── */}
                <article class:list={[
                    "note-timeline__card card-base",
                    item.entry.data.pinned && "note-timeline__card--pinned",
                ]}>
                    {/* 顶部：置顶 + 更新时间 */}
                    {(item.entry.data.pinned || item.updatedLabel) && (
                        <header class="note-card__meta">
                            {item.entry.data.pinned && (
                                <span class="note-pin-badge">
                                    <Icon name="material-symbols:push-pin" class="text-[0.75rem]" />
                                    {i18n(I18nKey.pinned)}
                                </span>
                            )}
                            {item.updatedLabel && updatedDateTime && (
                                <time datetime={updatedDateTime} class="note-updated">
                                    <Icon name="material-symbols:history" class="text-[0.75rem]" />
                                    {item.updatedLabel}
                                </time>
                            )}
                        </header>
                    )}

                    {/* 正文 */}
                    <div class="note-card__body" data-pagefind-body>
                        <Markdown class="note-markdown">
                            <Content />
                        </Markdown>
                    </div>

                    {/* 图片网格 */}
                    {images.length > 0 && (
                        <div class:list={[
                            "note-images",
                            images.length === 1 && "note-images--single",
                            images.length === 2 && "note-images--double",
                            images.length === 3 && "note-images--triple",
                            images.length >= 4 && "note-images--grid",
                        ]}>
                            {images.map((src) => (
                                <a href={src} data-fancybox={`note-${index}`} class="note-img-wrap">
                                    <img src={src} alt="" loading="lazy" decoding="async" class="note-img" />
                                </a>
                            ))}
                        </div>
                    )}

                    {/* footer：时间 / 标签 / 地点 / mood */}
                    <footer class="note-card__footer">
                        <div class="note-footer__left">
                            <Icon name="material-symbols:schedule-outline" class="text-[0.75rem]" />
                            <time datetime={item.entry.data.published.toISOString()}>
                                {item.publishedLabel}
                            </time>
                        </div>
                        <div class="note-footer__right">
                            {tags.length > 0 && (
                                <div class="note-tags">
                                    {tags.map((tag: string) => (
                                        <span class="note-tag">#{tag}</span>
                                    ))}
                                </div>
                            )}
                            {location && (
                                <span class="note-footer__meta">
                                    <Icon name="material-symbols:location-on-outline" class="text-[0.75rem]" />
                                    {location}
                                </span>
                            )}
                            {mood && <span class="note-footer__meta">{mood}</span>}
                        </div>
                    </footer>

                    {/* hover 渐变遮罩 */}
                    <div class="note-card__overlay" aria-hidden="true"></div>
                </article>
            </li>
        );
    })}
</ul>
</div>

<style>
/* 外层大卡片 */
.notes-wrapper {
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 3vw, 2rem);
    margin-bottom: clamp(2.75rem, 4vw, 3.5rem);
}

/* ══════════════════════════════════════
   Timeline 列表
══════════════════════════════════════ */
.note-timeline {
    --tl: color-mix(in srgb, var(--primary) 82%, white 18%);
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 3.5vw, 4rem);
}

/* 三列：日期 | 轴线 | 卡片 */
.note-timeline__item {
    display: grid;
    grid-template-columns: minmax(4.5rem, auto) 2.5rem minmax(0, 1fr);
    column-gap: clamp(1.1rem, 2vw, 1.75rem);
    align-items: stretch;
    min-width: 0;
}

/* ── 左：日期 ── */
.note-timeline__time {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-start;
    gap: 0.2rem;
    padding-top: 0.2rem;
    color: color-mix(in srgb, var(--tl) 75%, var(--foreground, currentColor) 25%);
    text-align: right;
    font-feature-settings: "tnum";
}
.note-timeline__day   { font-size: clamp(1.9rem, 2.2vw + 1rem, 2.65rem); font-weight: 700; letter-spacing: -0.04em; }
.note-timeline__month { font-size: clamp(0.85rem, 0.55vw + 0.75rem, 1rem); opacity: 0.75; font-weight: 500; }
.note-timeline__year  { font-size: 0.7rem; letter-spacing: 0.08em; opacity: 0.55; }

/* ── 中：轴线 ── */
.note-timeline__axis {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    z-index: 1;
}
/* 连接线：从当前 dot 底部 → 下一个 dot 顶部，不穿过 dot */
.note-timeline__item:not(:last-child):not(:only-child) .note-timeline__axis::before {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    background: linear-gradient(
        to bottom,
        transparent,
        color-mix(in srgb, var(--tl) 40%, transparent) 15%,
        color-mix(in srgb, var(--tl) 40%, transparent) 85%,
        transparent
    );
    pointer-events: none;
    z-index: 0;
    /* dot: margin-top 0.35rem + height 0.85rem = 底边在 1.2rem */
    top: 1.8rem;
    /* 向下穿过本 item 剩余高度 + gap + 下一个 dot 的 margin-top */
    bottom: calc(-1 * clamp(2.5rem, 3.5vw, 4rem) - 0.35rem);
}
.note-timeline__item:only-child .note-timeline__axis::before { display: none; }

.note-timeline__dot {
    position: relative;
    margin-top: 0.2rem;
    align-self: flex-start;
    width: 1.6rem;
    height: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    line-height: 1;
    color: color-mix(in srgb, var(--tl) 80%, transparent);
    transition: transform 0.25s ease, color 0.25s ease;
    z-index: 1;
    user-select: none;
}
.note-timeline__dot::before {
    content: "★";
}
.note-timeline__dot--pinned { color: var(--primary); }
.note-timeline__item:hover .note-timeline__dot {
    transform: scale(1.25) rotate(20deg);
    color: var(--primary);
}

/* ══════════════════════════════════════
   卡片
══════════════════════════════════════ */
.note-timeline__card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: clamp(0.85rem, 2vw, 1.2rem) clamp(1rem, 2.5vw, 1.5rem);
    background: color-mix(in srgb, var(--primary) 16%, var(--card-bg));
    box-shadow: 0 4px 24px -18px rgba(0,0,0,0.3);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}
.note-timeline__item:hover .note-timeline__card {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--tl) 40%, transparent);
    box-shadow: 0 12px 32px -18px rgba(0,0,0,0.18);
}
.note-timeline__card--pinned {
    border-color: color-mix(in srgb, var(--primary) 40%, transparent);
    background: color-mix(in srgb, var(--card-bg) 95%, color-mix(in srgb, var(--primary) 12%, transparent));
}

/* 顶部 meta */
.note-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}
.note-pin-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary) 14%, transparent);
    color: var(--primary);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.05em;
}
.note-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    font-size: 0.65rem;
    color: color-mix(in srgb, currentColor 45%, transparent);
    background: color-mix(in srgb, var(--tl) 10%, transparent);
    padding: 0.08rem 0.38rem;
    border-radius: 999px;
}

/* 正文 */
.note-card__body { position: relative; }
.note-markdown {
    font-size: clamp(0.85rem, 0.35vw + 0.78rem, 0.92rem);
    line-height: 1.7;
    max-height: 16rem;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--tl) 25%, transparent) transparent;
}
.note-markdown::-webkit-scrollbar { width: 3px; }
.note-markdown::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--tl) 28%, transparent);
    border-radius: 999px;
}

/* 图片网格 */
.note-images { display: grid; gap: 0.3rem; }
.note-images--single { grid-template-columns: 1fr; max-width: 20rem; }
.note-images--double { grid-template-columns: repeat(2, 1fr); max-width: 24rem; }
.note-images--triple { grid-template-columns: repeat(2, 1fr); max-width: 24rem; }
.note-images--triple .note-img-wrap:first-child { grid-row: span 2; }
.note-images--grid   { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); }
@media (max-width: 480px) {
    .note-images--triple .note-img-wrap:first-child { grid-row: span 1; }
    .note-images--triple { grid-template-columns: repeat(2, 1fr); }
}
.note-img-wrap {
    display: block;
    aspect-ratio: 1;
    border-radius: 0.4rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--primary) 6%, var(--card-bg));
}
.note-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
.note-img-wrap:hover .note-img { transform: scale(1.06); }

/* footer */
.note-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.68rem;
    color: color-mix(in srgb, var(--primary) 55%, currentColor 45%);
    flex-wrap: wrap;
    gap: 0.35rem;
    padding-top: 0.3rem;
    border-top: 1px solid color-mix(in srgb, currentColor 50%, transparent);
}
.note-footer__left, .note-footer__right { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
.note-footer__meta { display: inline-flex; align-items: center; gap: 0.15rem; }

/* 标签 */
.note-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
.note-tag {
    font-size: 0.62rem;
    color: var(--primary);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    padding: 0.08rem 0.4rem;
    border-radius: 999px;
    font-weight: 500;
    transition: background 0.15s ease;
}
.note-tag:hover { background: color-mix(in srgb, var(--primary) 20%, transparent); }

/* hover 遮罩 */
.note-card__overlay {
    pointer-events: none;
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 5%, transparent), transparent 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: inherit;
}
.note-timeline__item:hover .note-card__overlay { opacity: 1; }

/* 暗色模式 */
:global(.dark) .note-timeline { --tl: color-mix(in srgb, var(--primary) 70%, white 8%); }
:global(.dark) .note-timeline__card {
    background: color-mix(in srgb, var(--primary) 12%, var(--card-bg));
}

/* 移动端 */
@media (max-width: 768px) {
    .note-timeline__item {
        grid-template-columns: minmax(2.9rem, auto) 1.3rem minmax(0, 1fr);
        column-gap: clamp(0.55rem, 1.5vw, 0.85rem);
    }
    .note-timeline__day   { font-size: clamp(1.45rem, 1.6vw + 1rem, 1.9rem); }
    .note-timeline__month { font-size: 0.85rem; }
    .note-timeline__year  { font-size: 0.62rem; }
    .note-timeline__card  { padding: 0.8rem 1rem; }
}
</style>
