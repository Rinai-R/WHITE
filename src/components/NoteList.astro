---
import type { CollectionEntry } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/config";
import NoteImageWrapper from "@components/misc/NoteImageWrapper.astro";
import path from "node:path";
import { getDir } from "@utils/url-utils";

const { page } = Astro.props;
const interval = 40;

function getMonthLabel(monthNumber: number): string {
	const lang = (siteConfig.lang || "en").toLowerCase();
	if (lang.startsWith("zh") || lang.startsWith("ja")) return `${monthNumber}月`;
	if (lang.startsWith("ko")) return `${monthNumber}월`;
	const names = [
		"Jan",
		"Feb",
		"Mar",
		"Apr",
		"May",
		"Jun",
		"Jul",
		"Aug",
		"Sep",
		"Oct",
		"Nov",
		"Dec",
	];
	if (!Number.isFinite(monthNumber) || monthNumber < 1 || monthNumber > 12)
		return String(monthNumber);
	return names[monthNumber - 1];
}

const notes = await Promise.all(
	page.data.map(async (entry: CollectionEntry<"notes">) => {
		const { Content } = await entry.render();
		const publishedLabel = formatDateToYYYYMMDD(entry.data.published);
		const updatedLabel =
			entry.data.updated &&
			entry.data.updated.getTime() !== entry.data.published.getTime()
				? formatDateToYYYYMMDD(entry.data.updated)
				: null;
		const [year, month, day] = publishedLabel.split("-");
		const monthNum = Number.parseInt(month, 10);
		const dayNum = Number.parseInt(day, 10);
		return {
			entry,
			Content,
			publishedLabel,
			updatedLabel,
			dateParts: {
				year,
				month:
					Number.isFinite(monthNum) && monthNum >= 1 && monthNum <= 12
						? getMonthLabel(monthNum)
						: month,
				day: Number.isFinite(dayNum) ? String(dayNum).padStart(2, "0") : day,
			},
		};
	}),
);
---

<div class="notes-wrapper card-base">
<ul class="note-timeline">
    {notes.map((item, index) => {
        const Content = item.Content;
        const images: string[]   = item.entry.data.images ?? [];
        const tags: string[]     = item.entry.data.tags ?? [];
        const mood: string       = item.entry.data.mood ?? "";
        const location: string   = item.entry.data.location ?? "";
        const updatedDateTime    = item.entry.data.updated?.toISOString();

        return (
            <li
                class:list={[
                    "note-timeline__item onload-animation",
                    item.entry.data.pinned && "note-timeline__item--pinned",
                ]}
                style={`animation-delay: calc(var(--content-delay) + ${index * interval}ms);`}
            >
                {/* ── 左：日期 ── */}
                <div class="note-timeline__time">
                    <span class="note-timeline__day">{item.dateParts.day}</span>
                    <span class="note-timeline__month">{item.dateParts.month}</span>
                    <span class="note-timeline__year">{item.dateParts.year}</span>
                </div>

                {/* ── 中：轴线 ── */}
                <div class="note-timeline__axis" aria-hidden="true">
                    <span class:list={[
                        "note-timeline__dot",
                        item.entry.data.pinned && "note-timeline__dot--pinned",
                    ]}></span>
                </div>

                {/* ── 右：卡片 ── */}
                <article class:list={[
                    "note-timeline__card card-base group",
                    item.entry.data.pinned && "note-timeline__card--pinned",
                ]}>
                    {/* 顶部：置顶 + 更新时间 + Mood + Location */}
                    <header class="note-card__header flex items-center gap-2 mb-3 flex-wrap">
                        {item.entry.data.pinned && (
                            <span class="note-pin-badge inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-[color-mix(in_srgb,var(--primary)_15%,transparent)] text-xs text-[var(--primary)] font-bold tracking-wider uppercase">
                                <Icon name="material-symbols:push-pin" class="text-[0.85rem]" />
                                {i18n(I18nKey.pinned)}
                            </span>
                        )}
                        {mood && (
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-lg bg-[color-mix(in_srgb,var(--primary)_12%,transparent)] text-xs text-[var(--primary)] font-medium">
                                {mood}
                            </span>
                        )}
                        {location && (
                            <span class="inline-flex items-center gap-1 text-xs text-black/50 dark:text-white/50">
                                <Icon name="material-symbols:location-on-outline" class="text-[0.8rem]" />
                                {location}
                            </span>
                        )}
                        {item.updatedLabel && updatedDateTime && (
                            <time datetime={updatedDateTime} class="note-updated ml-auto">
                                <Icon name="material-symbols:history" class="text-[0.75rem]" />
                                {item.updatedLabel}
                            </time>
                        )}
                    </header>

                    {/* 正文 */}
                    <div class="note-card__body" data-pagefind-body>
                        <Markdown class="note-markdown">
                            <Content />
                        </Markdown>
                    </div>

                    {/* 图片网格 (Mizuki-style) */}
                    {images.length > 0 && (
                        <div class:list={[
                            "note-images mt-3",
                            images.length === 1 && "note-images--single",
                            images.length === 2 && "note-images--double",
                            images.length === 3 && "note-images--triple",
                            images.length >= 4 && "note-images--grid",
                        ]}>
                            {images.map((src, imgIndex) => (
                                <a href={src.startsWith('http') ? src : undefined} data-fancybox={`note-${index}-${imgIndex}`} class="note-img-wrap block w-full h-full">
                                    <NoteImageWrapper 
                                        src={src} 
                                        basePath={path.join("content/notes/", getDir(item.entry.id))}
                                        class="note-img w-full h-full object-cover transition-transform duration-300 hover:scale-105" 
                                    />
                                </a>
                            ))}
                        </div>
                    )}

                    {/* 标签网格 (Mizuki-style pill badges) */}
                    {tags.length > 0 && (
                        <div class="note-tags-container mt-3">
                            <div class="flex flex-wrap gap-1.5">
                                {tags.map((tag: string) => (
                                    <span class="btn-regular h-6 text-xs px-2.5 rounded-lg flex items-center justify-center font-medium">
                                        #{tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                    )}

                    <hr class="border-t border-black/5 dark:border-white/5 my-3" />

                    {/* footer：时间 */}
                    <footer class="note-card__footer flex items-center justify-between text-xs text-black/50 dark:text-white/50 flex-wrap gap-2">
                        <div class="flex items-center gap-1.5">
                            <Icon name="material-symbols:schedule-outline" class="text-[0.8rem]" />
                            <time datetime={item.entry.data.published.toISOString()}>
                                {item.publishedLabel}
                            </time>
                        </div>
                    </footer>

                    {/* hover 渐变遮罩 */}
                    <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-[inherit]"></div>
                </article>
            </li>
        );
    })}
</ul>
</div>

<style>
/* 外层大卡片 */
.notes-wrapper {
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 3vw, 2rem);
    margin-bottom: clamp(2.75rem, 4vw, 3.5rem);
}

/* ══════════════════════════════════════
   Timeline 列表
══════════════════════════════════════ */
.note-timeline {
    --tl: color-mix(in srgb, var(--primary) 82%, white 18%);
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 3.5vw, 4rem);
}

/* 三列：日期 | 轴线 | 卡片 */
.note-timeline__item {
    display: grid;
    grid-template-columns: minmax(4.5rem, auto) 2.5rem minmax(0, 1fr);
    column-gap: clamp(1.1rem, 2vw, 1.75rem);
    align-items: stretch;
    min-width: 0;
}

/* ── 左：日期 ── */
.note-timeline__time {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-start;
    gap: 0.2rem;
    padding-top: 0.2rem;
    color: color-mix(in srgb, var(--tl) 75%, var(--foreground, currentColor) 25%);
    text-align: right;
    font-feature-settings: "tnum";
}
.note-timeline__day   { font-size: clamp(1.9rem, 2.2vw + 1rem, 2.65rem); font-weight: 700; letter-spacing: -0.04em; }
.note-timeline__month { font-size: clamp(0.85rem, 0.55vw + 0.75rem, 1rem); opacity: 0.75; font-weight: 500; }
.note-timeline__year  { font-size: 0.7rem; letter-spacing: 0.08em; opacity: 0.55; }

/* ── 中：轴线 ── */
.note-timeline__axis {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    z-index: 1;
}
/* 连接线：从当前 dot 底部 → 下一个 dot 顶部，不穿过 dot */
.note-timeline__item:not(:last-child):not(:only-child) .note-timeline__axis::before {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    background: linear-gradient(
        to bottom,
        transparent,
        color-mix(in srgb, var(--tl) 40%, transparent) 15%,
        color-mix(in srgb, var(--tl) 40%, transparent) 85%,
        transparent
    );
    pointer-events: none;
    z-index: 0;
    /* dot: margin-top 0.35rem + height 0.85rem = 底边在 1.2rem */
    top: 1.8rem;
    /* 向下穿过本 item 剩余高度 + gap + 下一个 dot 的 margin-top */
    bottom: calc(-1 * clamp(2.5rem, 3.5vw, 4rem) - 0.35rem);
}
.note-timeline__item:only-child .note-timeline__axis::before { display: none; }

.note-timeline__dot {
    position: relative;
    margin-top: 0.2rem;
    align-self: flex-start;
    width: 0.6rem;
    height: 0.6rem;
    margin-left: 0.5rem;
    margin-right: 0.5rem;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--tl) 60%, transparent);
    transition: transform 0.3s ease, background-color 0.3s ease, box-shadow 0.3s ease;
    z-index: 1;
}
.note-timeline__dot--pinned { 
    background-color: var(--primary); 
    box-shadow: 0 0 8px color-mix(in srgb, var(--primary) 50%, transparent);
}
.note-timeline__item:hover .note-timeline__dot {
    transform: scale(1.5);
    background-color: var(--primary);
    box-shadow: 0 0 12px color-mix(in srgb, var(--primary) 40%, transparent);
}

/* ══════════════════════════════════════
   卡片
══════════════════════════════════════ */
.note-timeline__card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: clamp(1rem, 2.5vw, 1.25rem);
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--foreground, currentColor) 8%, transparent);
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px -2px rgba(0,0,0,0.05);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.note-timeline__item:hover .note-timeline__card {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
    box-shadow: 0 8px 24px -6px rgba(0,0,0,0.12);
}
.note-timeline__card--pinned {
    border-color: color-mix(in srgb, var(--primary) 40%, transparent);
    background: color-mix(in srgb, var(--primary) 3%, transparent);
}

/* 顶部 meta */
.note-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    font-size: 0.7rem;
    color: color-mix(in srgb, currentColor 45%, transparent);
    background: color-mix(in srgb, var(--tl) 10%, transparent);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
}

/* 正文 */
.note-card__body { position: relative; }
.note-markdown {
    font-size: clamp(0.85rem, 0.35vw + 0.78rem, 0.92rem);
    line-height: 1.7;
    max-height: 16rem;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--tl) 25%, transparent) transparent;
}
.note-markdown::-webkit-scrollbar { width: 3px; }
.note-markdown::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--tl) 28%, transparent);
    border-radius: 999px;
}

/* 图片网格 (响应式 Mizuki 风格) */
.note-images { display: grid; gap: 0.5rem; }
.note-images--single { grid-template-columns: 1fr; max-width: 400px; }
.note-images--double { grid-template-columns: repeat(2, 1fr); max-width: 500px; }
.note-images--triple { grid-template-columns: repeat(2, 1fr); max-width: 500px; }
.note-images--triple .note-img-wrap:first-child { grid-row: span 2; }
.note-images--grid   { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); max-width: 600px; }
@media (min-width: 768px) {
    .note-images--single { max-width: 500px; }
    .note-images--double { max-width: 560px; }
    .note-images--grid   { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); max-width: 700px; }
}
@media (max-width: 480px) {
    .note-images--triple .note-img-wrap:first-child { grid-row: span 1; }
}
.note-img-wrap {
    display: block;
    aspect-ratio: 1;
    border-radius: 0.5rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--foreground, currentColor) 4%, transparent);
}
.note-img { width: 100%; height: 100%; object-fit: cover; }

/* 暗色模式覆盖 */
:global(.dark) .note-timeline { --tl: color-mix(in srgb, var(--primary) 70%, white 8%); }
:global(.dark) .note-timeline__card {
    border-color: color-mix(in srgb, white 10%, transparent);
    box-shadow: 0 2px 8px -2px rgba(0,0,0,0.2);
}
:global(.dark) .note-timeline__item:hover .note-timeline__card {
    border-color: color-mix(in srgb, var(--primary) 40%, transparent);
    box-shadow: 0 8px 24px -6px rgba(0,0,0,0.4);
}
:global(.dark) .note-timeline__card--pinned {
    background: color-mix(in srgb, var(--primary) 8%, transparent);
}

/* 移动端 */
@media (max-width: 768px) {
    .note-timeline__item {
        grid-template-columns: minmax(2.9rem, auto) 1.3rem minmax(0, 1fr);
        column-gap: clamp(0.55rem, 1.5vw, 0.85rem);
    }
    .note-timeline__day   { font-size: clamp(1.45rem, 1.6vw + 1rem, 1.9rem); }
    .note-timeline__month { font-size: 0.85rem; }
    .note-timeline__year  { font-size: 0.62rem; }
    .note-timeline__card  { padding: 0.8rem 1rem; }
}
</style>
