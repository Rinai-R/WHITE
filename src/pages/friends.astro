---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import friendsItems from "../_data/friends.json";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const friendsPage = await getEntry("spec", "friends");

if (!friendsPage) {
	throw new Error("Friends page content not found");
}

const { Content } = await render(friendsPage);

const items = friendsItems;
const interval = 50;
---
<MainGridLayout title={i18n(I18nKey.friends)} description={i18n(I18nKey.friends)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 mb-4">
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
            <Markdown class="mb-2">
                <Content/>
            </Markdown>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-4">
                {items.map((item, index) => (
                    <a href={item.siteUrl} target="_blank" rel="noopener noreferrer"
                       class="friend-card group onload-animation"
                       style={`animation-delay: calc(var(--content-delay) + ${index * interval}ms);`}>
                        {/* 左侧主题色指示条 */}
                        <div class="friend-card__bar"></div>
                        <div class="friend-card__avatar">
                            <img src={item.siteIcon} alt={item.siteTitle} class="w-full h-full object-cover" loading="lazy">
                        </div>
                        <div class="friend-card__body">
                            <div class="friend-card__title">{item.siteTitle}</div>
                            <div class="friend-card__desc">{item.siteDesc}</div>
                        </div>
                        <div class="friend-card__arrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M6.4 18L5 16.6L14.6 7H8V5h11v11h-2V9.4z"></path>
                            </svg>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </div>
</MainGridLayout>

<style>
.friend-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1rem 1rem 1.125rem;
    border: 1px solid color-mix(in srgb, currentColor 7%, transparent);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.friend-card:hover {
    border-color: color-mix(in srgb, var(--primary) 25%, transparent);
    background: color-mix(in srgb, var(--primary) 3%, transparent);
}

.friend-card:active {
    transform: scale(0.985);
    background: color-mix(in srgb, var(--primary) 5%, transparent);
}

/* 左侧指示条 */
.friend-card__bar {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) scaleY(0);
    width: 3px;
    height: 60%;
    border-radius: 0 3px 3px 0;
    background: var(--primary);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.friend-card:hover .friend-card__bar {
    transform: translateY(-50%) scaleY(1);
}

/* 头像 */
.friend-card__avatar {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: color-mix(in srgb, currentColor 5%, transparent);
    transition: box-shadow 0.3s ease;
}

.friend-card:hover .friend-card__avatar {
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--primary) 30%, transparent);
}

/* 文字区 */
.friend-card__body {
    flex: 1;
    min-width: 0;
}

/* 标题 */
.friend-card__title {
    font-weight: 600;
    font-size: 0.9rem;
    color: rgba(0, 0, 0, 0.88);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.3s ease;
    line-height: 1.4;
}

.friend-card:hover .friend-card__title {
    color: var(--primary);
}

/* 描述 */
.friend-card__desc {
    font-size: 0.76rem;
    color: rgba(0, 0, 0, 0.4);
    line-height: 1.5;
    margin-top: 0.125rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

/* 箭头 */
.friend-card__arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: var(--primary);
    opacity: 0;
    transform: translate(-3px, 3px);
    transition: opacity 0.3s ease, transform 0.3s ease;
}

.friend-card:hover .friend-card__arrow {
    opacity: 0.6;
    transform: translate(0, 0);
}

/* 暗色模式 */
:global(.dark) .friend-card {
    border-color: color-mix(in srgb, white 8%, transparent);
}

:global(.dark) .friend-card:hover {
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
    background: color-mix(in srgb, var(--primary) 5%, transparent);
}

:global(.dark) .friend-card:active {
    background: color-mix(in srgb, var(--primary) 8%, transparent);
}

:global(.dark) .friend-card__title {
    color: rgba(255, 255, 255, 0.88);
}

:global(.dark) .friend-card__desc {
    color: rgba(255, 255, 255, 0.4);
}

:global(.dark) .friend-card__avatar {
    background: color-mix(in srgb, white 5%, transparent);
}

:global(.dark) .friend-card:hover .friend-card__avatar {
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--primary) 35%, transparent);
}
</style>
